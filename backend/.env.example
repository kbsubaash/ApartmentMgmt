# Backend Environment Variables

# Database Configuration
# For PostgreSQL (production): postgresql://user:password@host:5432/database
# For SQLite (development): file:./prisma/dev.db
DATABASE_URL="file:./prisma/dev.db"

# Node Environment: development | production | test
NODE_ENV=development

# Server Port
PORT=5000

# JWT Configuration (generate strong random secrets)
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS - frontend origin
CLIENT_ORIGIN=http://localhost:5173

# File uploads directory
UPLOAD_DIR=uploads

# SMTP Email Configuration (Nodemailer)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASS=your-app-password
MAIL_FROM=noreply@dabc-euphorbia.com

# Seed Script Defaults
SEED_ADMIN_EMAIL=admin@dabc-euphorbia.com
SEED_ADMIN_PASSWORD=Admin@1234
SEED_ADMIN_NAME=Association Admin

# Error Tracking (Optional - Sentry)
SENTRY_DSN=

# Rate Limiting (Optional)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
SMTP_FROM=noreply@dabc-euphorbia.com

# Seed script
SEED_ADMIN_EMAIL=admin@dabc-euphorbia.com
SEED_ADMIN_PASSWORD=Admin@1234
SEED_ADMIN_NAME=Association Admin
